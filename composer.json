    "require": {
        "rosell-dk/webp-convert": "^2.9",
        "maatify/logger": "^5.0",
        "ext-fileinfo": "*",
        "maatify/json": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Maatify\\WebPConverter\\": "webp-convert/",
            "Maatify\\Uploader\\": "uploader/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },

    "require-dev": {
        "ext-gd": "*",

        "phpunit/phpunit": "^9.6",
        "aws/aws-sdk-php": "^3.374",
        "phpstan/phpstan": "^1.11"

    },

    "suggest": {
        "aws/aws-sdk-php": "Required for DO Spaces or S3 storage support"
    },


    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse uploader webp-convert --level=max"
    }
}
